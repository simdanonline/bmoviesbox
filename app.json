{
  "expo": {
    "name": "BMovieBox",
    "slug": "bmoviebox",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.simdanonline.bmoviebox",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.simdanonline.bmoviebox"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "@react-native-tvos/config-tv",
        {
          "androidTVBanner": "./assets/images/tv-banner.png",
          "isTV": false
        }
      ],
      ["expo-video"],
      [
        "react-native-video",
        {
          "enableNotificationControls": false,
          "androidExtensions": {
            "useExoplayerRtsp": false,
            "useExoplayerSmoothStreaming": false,
            "useExoplayerHls": true,
            "useExoplayerDash": false
          }
        }
      ],
      "react-native-vlc-media-player",
      "@kesha-antonov/react-native-background-downloader",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#e74c3c"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9d699527-d904-4cfd-b9a4-e644e73fbd56"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9d699527-d904-4cfd-b9a4-e644e73fbd56",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 30000
    }
  }
}

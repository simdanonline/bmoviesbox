# BMovieBox Environment Configuration

# API Configuration
# Set the API base URL (without /api suffix)
# Default: http://localhost:3001
# REACT_APP_API_URL=http://localhost:3001
# App Configuration
REACT_APP_NAME=BMovieBox
REACT_APP_VERSION=1.0.0

# Timeout in milliseconds for API requests
REACT_APP_API_TIMEOUT=15000

# Enable detailed logging
REACT_APP_DEBUG=false

# TMDB API key (v3) — used to look up a title's original language so playback
# can enforce original (non-dubbed) audio. Must be EXPO_PUBLIC_-prefixed so
# Expo inlines it into the bundle (process.env.EXPO_PUBLIC_TMDB_API_KEY).
# Get a free key at https://www.themoviedb.org/settings/api
# Without it, the original-audio preference silently no-ops.
EXPO_PUBLIC_TMDB_API_KEY=
